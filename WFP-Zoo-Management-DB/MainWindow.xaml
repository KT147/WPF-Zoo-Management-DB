<Window x:Class="WFP_Zoo_Management_DB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WFP_Zoo_Management_DB"
        mc:Ignorable="d"
        Title="Zoo Manager" Height="500" Width="700">
    <Grid>
        <Label Content="Zoo List" HorizontalAlignment="Left" Margin="40,41,0,0" VerticalAlignment="Top"/>
        <ListBox Name="listZoos" SelectionChanged="listZoos_SelectionChanged"  Margin="10,86,496,172">

        </ListBox>
        <Label Content="Associated Animals List&#xD;&#xA;" HorizontalAlignment="Left" Margin="261,41,0,0" VerticalAlignment="Top"/>
        <ListBox Name="listAssociatedAnimals"  Margin="245,86,261,172">

        </ListBox>
        <ListBox x:Name="listAnimals"  Margin="471,86,35,68" SelectionChanged="listAnimals_SelectionChanged"/>

        <Button Content="Delete Zoo" HorizontalAlignment="Left" Margin="10,330,0,0" VerticalAlignment="Top" Width="194" Click="DeleteZoo_Click"/>
        <Button Content="Remove Animal" HorizontalAlignment="Left" Margin="245,330,0,0" VerticalAlignment="Top" Width="194" Click="DeleteAssociatedAnimal_Click"/>
        <Button Content="Add Zoo" HorizontalAlignment="Left" Margin="10,396,0,0" VerticalAlignment="Top" Width="194" Click="AddZoo_Click"/>
        <Button Content="Update Zoo" HorizontalAlignment="Left" Margin="10,432,0,0" VerticalAlignment="Top" Width="194" Click="UpdateZoo_Click"/>
        <Button Content="Add Animal" HorizontalAlignment="Left" Margin="245,396,0,0" VerticalAlignment="Top" Width="194"  Click="AddAnimal_Click"/>
        <Button Content="Update Animal" HorizontalAlignment="Left" Margin="245,432,0,0" VerticalAlignment="Top" Width="194" Click="UpdateAnimal_Click"/>
        <Button Content="Add Animal to Zoo" HorizontalAlignment="Left" Margin="471,42,0,0" VerticalAlignment="Top" Width="194" Click="AddAnimalToZoo_Click" />
        <Button Content="Delete Animal" HorizontalAlignment="Left" Margin="471,432,0,0" VerticalAlignment="Top" Width="194" Click="DeleteAnimal_Click" />
        <TextBox Name="myTextBox" HorizontalAlignment="Left" Margin="10,355,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="429" Height="33"/>

    </Grid>
</Window>
